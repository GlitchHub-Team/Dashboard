{
  "name": "Dashboard Dev (Go + Angular)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": [
    3001,
    4200
  ],
  "portsAttributes": {
    "3001": {
      "label": "Dashboard Backend"
    },
    "4200": {
      "label": "Angular Dev Server"
    }
  },
  "postCreateCommand": "bash .devcontainer/init.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "go.lintTool": "golangci-lint",
        "go.useLanguageServer": true,
        "go.formatTool": "gofumpt",
        "go.toolsManagement.autoUpdate": false,
        "go.alternateTools": {
          "golangci-lint": "/usr/local/bin/golangci-lint",
          "gofumpt": "/home/vscode/go/bin/gofumpt",
          "gopls": "/home/vscode/go/bin/gopls",
          "dlv": "/home/vscode/go/bin/dlv"
        }
      },
      "extensions": [
        "golang.go",
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        "tamasfe.even-better-toml"
      ]
    }
  }
}
